# Root .gitignore for City-Shield-AI

# Node
node_modules/

# Next.js
.next/
/out/

# Build outputs
dist/
build/

# Environment
.env
.env.local
.env.*.local

# Vercel
.vercel/

# TypeScript
*.tsbuildinfo

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/

# Yarn Plug'n'Play
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Coverage reports
coverage/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Ignore built frontend artifacts if present
frontend/.next/
frontend/node_modules/
frontend/dist/

# Ignore backend node modules
backend/node_modules/

# Local blockchain/data dumps
backend/data/
